---
interface Props {
  label: string;
  align?: 'left' | 'right';
}
const { label, align = 'left' } = Astro.props;
---

<div
  class:list={[
    'flex items-center gap-2',
    align === 'right' && 'justify-end',
  ]}
>
  {align === 'left' && <span class="block w-6 h-px bg-accent"></span>}
  <span class="mono-label">{label}</span>
  {align === 'right' && <span class="block w-6 h-px bg-accent"></span>}
</div>
