---
const year = new Date().getFullYear();
---

<footer class="border-t border-hairline border-border-subtle mt-section">
  <div class="mx-auto max-w-page px-8 py-10 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <p class="font-mono text-mono-meta uppercase tracking-wide text-text-tertiary">
      &copy; {year} stewart burton &middot; cape town, south africa
    </p>
    <ul class="flex items-center gap-6">
      <li>
        <a
          href="https://github.com/stewartburton"
          class="font-mono text-mono-label uppercase tracking-wider text-text-tertiary hover:text-accent transition-colors"
          rel="me noopener"
        >
          github
        </a>
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/stewart-burton/"
          class="font-mono text-mono-label uppercase tracking-wider text-text-tertiary hover:text-accent transition-colors"
          rel="me noopener"
        >
          linkedin
        </a>
      </li>
      <li>
        <a
          href="mailto:stewart@stewart-burton.com"
          class="font-mono text-mono-label uppercase tracking-wider text-text-tertiary hover:text-accent transition-colors"
        >
          email
        </a>
      </li>
    </ul>
  </div>
</footer>
