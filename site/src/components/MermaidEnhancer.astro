---
// Walks the rendered prose for ```mermaid``` code blocks and promotes
// them to <pre class="mermaid"> blocks so the upstream Mermaid script
// in Mermaid.astro picks them up.
---

<script>
  document.querySelectorAll('pre > code.language-mermaid').forEach((code) => {
    const pre = code.parentElement!;
    const wrapper = document.createElement('div');
    wrapper.className = 'rounded-card border border-border-subtle bg-bg-card-elevated p-6 my-6 overflow-x-auto';
    const target = document.createElement('pre');
    target.className = 'mermaid font-mono text-[13px] text-text-body';
    target.textContent = code.textContent ?? '';
    wrapper.appendChild(target);
    pre.replaceWith(wrapper);
  });

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const w = window as any;
  if (!w.__mermaidLoaded && document.querySelector('pre.mermaid')) {
    w.__mermaidLoaded = true;
    import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs').then(({ default: mermaid }) => {
      mermaid.initialize({
        startOnLoad: false,
        theme: 'base',
        themeVariables: {
          darkMode: true,
          background: '#0a0a0a',
          primaryColor: '#141414',
          primaryTextColor: '#f5f5f5',
          primaryBorderColor: '#262626',
          secondaryColor: '#111111',
          secondaryTextColor: '#a3a3a3',
          secondaryBorderColor: '#1f1f1f',
          tertiaryColor: '#5eead4',
          tertiaryTextColor: '#0a0a0a',
          tertiaryBorderColor: '#5eead4',
          lineColor: '#404040',
          fontFamily: '"JetBrains Mono", "Geist Mono", monospace',
          fontSize: '13px',
        },
      });
      mermaid.run({ querySelector: 'pre.mermaid' });
    });
  }
</script>
