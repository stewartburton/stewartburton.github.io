---
interface Props {
  chart: string;
  id?: string;
}
const { chart, id } = Astro.props;
const blockId = id ?? `mermaid-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="card-elevated p-6 my-6 overflow-x-auto">
  <pre class="mermaid font-mono text-card-body" data-mermaid-id={blockId}>{chart}</pre>
</div>

<script>
  // load mermaid lazily once per page
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const w = window as any;
  if (!w.__mermaidLoaded) {
    w.__mermaidLoaded = true;
    import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs').then(({ default: mermaid }) => {
      mermaid.initialize({
        startOnLoad: true,
        theme: 'base',
        themeVariables: {
          darkMode: true,
          background: '#0a0a0a',
          primaryColor: '#141414',
          primaryTextColor: '#f5f5f5',
          primaryBorderColor: '#262626',
          secondaryColor: '#111111',
          secondaryTextColor: '#a3a3a3',
          secondaryBorderColor: '#1f1f1f',
          tertiaryColor: '#5eead4',
          tertiaryTextColor: '#0a0a0a',
          tertiaryBorderColor: '#5eead4',
          lineColor: '#404040',
          fontFamily: '"Geist Mono", "JetBrains Mono", monospace',
          fontSize: '13px',
        },
      });
      mermaid.run({ querySelector: 'pre.mermaid' });
    });
  }
</script>
